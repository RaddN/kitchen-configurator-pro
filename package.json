{
  "name": "kitchen-configurator-pro",
  "version": "1.0.0",
  "description": "Production-ready WordPress plugin for custom kitchen cabinet configuration with WooCommerce integration.",
  "directories": {
    "doc": "docs",
    "test": "tests"
  },
  "scripts": {
    "test": "npm run test:e2e:chromium",
    "test:e2e": "node node_modules/playwright/cli.js test",
    "test:e2e:chromium": "node node_modules/playwright/cli.js test --project=chromium",
    "test:e2e:headed": "node node_modules/playwright/cli.js test --project=chromium --headed",
    "test:unit": "node node_modules/vitest/vitest.mjs run",
    "report:e2e": "node node_modules/playwright/cli.js show-report"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.0",
    "@types/node": "^25.9.3",
    "chai": "^5.3.3",
    "jsdom": "^24.1.3",
    "vite": "^5.4.21",
    "vitest": "^2.1.9"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/RaddN/kitchen-configurator-pro.git"
  },
  "keywords": [],
  "author": "",
  "license": "GPL-2.0-or-later",
  "bugs": {
    "url": "https://github.com/RaddN/kitchen-configurator-pro/issues"
  },
  "homepage": "https://github.com/RaddN/kitchen-configurator-pro#readme"
}
